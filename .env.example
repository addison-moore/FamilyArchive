# FamilyArchive environment configuration
# Copy to .env and adjust. Full reference: docs/self-hosting/environment.md

# --- Required ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Optional (defaults shown) ---
#APP_URL=http://localhost:3000
#APP_PORT=3000
#POSTGRES_USER=familyarchive
#POSTGRES_PASSWORD=familyarchive
#POSTGRES_DB=familyarchive

# Local development outside Docker (services from `docker compose up postgres valkey`)
#DATABASE_URL=postgres://familyarchive:familyarchive@localhost:5432/familyarchive
#REDIS_URL=redis://localhost:6379

# --- Storage (Milestone 6; local driver is the default, PRD §24) ---
#MEDIA_STORAGE_DRIVER=local
#MEDIA_LOCAL_PATH=/data/media
#S3_ENDPOINT=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=
#S3_REGION=auto
#S3_FORCE_PATH_STYLE=true

# --- SMTP (Milestone 2; invite links work without it, PRD §9.3) ---
#SMTP_HOST=
#SMTP_PORT=587
#SMTP_USER=
#SMTP_PASSWORD=
#SMTP_FROM=

# --- Audit log retention in days (0 = keep forever, the default) ---
#AUDIT_RETENTION_DAYS=0

# --- OCR (Tesseract language codes, "+"-separated) ---
#OCR_LANGUAGES=eng

# --- External AI providers (disabled by default, PRD §31.4) ---
# Enables the explicit "Clean up OCR with AI" action; never called implicitly.
#AI_PROVIDER=
#AI_API_KEY=
#AI_MODEL=
